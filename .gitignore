# macOS legt diese Dateien automatisch an; sie haben keinen Projektwert.
.DS_Store
**/.DS_Store

# Geheimnisse und lokale Umgebung dürfen niemals versioniert werden.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Zugangsdaten aller Shape Miner Projekte (FTP/DB/SSH).
*SMDZ4-u-B-3-Rwo-r-t.md
Sha-peMin_*.md

# Lokale PHP-Konfiguration (enthält Secrets).
**/config.php

# Migrationsskript enthält DB-Zugangsdaten beider Systeme.
**/migration/migrieren.php

# Abhängigkeiten und Build-Ausgaben werden reproduzierbar erzeugt.
node_modules/
**/node_modules/
dist/
build/
coverage/

# Laufzeit- und Diagnoseausgaben gehören nicht ins Repository.
*.log
logs/

# Backups bleiben lokal, außer die bewusst gepflegte README.
BACKUPS/*
!BACKUPS/README.md

# Editor- und Betriebssystem-Zwischenstände.
.vscode/
.idea/
*.swp
*.swo
